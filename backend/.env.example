# Silent Honor Foundation — Backend Configuration
# Copy to `.env` and fill in real values. NEVER commit the filled-in .env (it is gitignored).

# ── Database ────────────────────────────────────────────────────────────────
# The service reads MONGO_URL/DB_NAME. MONGODB_URI/MONGODB_DB are also accepted
# (docker-compose sets those) — set either pair, not both.
MONGO_URL=mongodb://localhost:27017
DB_NAME=silenthonor

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-generate-a-long-random-value
JWT_EXPIRY_HOURS=24

# Seed admin (created on first startup). CHANGE THESE — do not ship the defaults.
ADMIN_EMAIL=admin@silenthonor.org
ADMIN_PASSWORD=change-me-strong-password

# ── Environment / CORS ──────────────────────────────────────────────────────
# ENVIRONMENT=production disables writing the dev test_credentials.md file.
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
# Comma-separated allowed browser origins. Leave blank to use the built-in defaults
# (both production domains + www + localhost). Set explicitly in production.
CORS_ORIGINS=

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@silenthonorfoundation.org

# ── DD-214 storage (Supabase, with encrypted local fallback) ────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
SUPABASE_BUCKET=dd214
# AES-256 (Fernet) key for encrypting DD-214 files stored on local disk.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DD214_ENCRYPTION_KEY=

# ── File upload / paths ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
# Where uploads are written (defaults to /app/uploads). Frontend dir is auto-detected;
# override with APP_DIR only if index.html/css/js live somewhere non-standard.
UPLOADS_DIR=/app/uploads
# APP_DIR=/var/www/silenthonor
# PORT=8000
