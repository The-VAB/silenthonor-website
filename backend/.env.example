# Silent Honor Foundation Backend Configuration
# Copy this file to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
# Local MongoDB:
MONGO_URL=mongodb://localhost:27017
DB_NAME=silenthonor
# Amazon DocumentDB (set instead of the above in AWS). Note tls params + CA bundle:
# MONGODB_URI=mongodb://<user>:<pass>@<cluster-endpoint>:27017/?tls=true&tlsCAFile=/app/rds-global-bundle.pem&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
# MONGODB_DB=silenthonor

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY_HOURS=24

# ── Email ───────────────────────────────────────────────────────────────────
# Provider: "ses" (live default) or "resend"
EMAIL_PROVIDER=ses
FROM_EMAIL=Silent Honor <no-reply@silenthonorfoundation.org>
ADMIN_EMAIL=admin@silenthonorfoundation.org
# SES uses the instance role / AWS credential chain — no key needed
# (domain silenthonorfoundation.org is DKIM-verified; account has production access).
# Resend (only if EMAIL_PROVIDER=resend):
# RESEND_API_KEY=re_your_resend_api_key

# ── File storage ────────────────────────────────────────────────────────────
# Amazon S3 (preferred). When S3_BUCKET is set, DD-214 + documents go to S3.
S3_BUCKET=silenthonor-uploads-802104113048
S3_KMS_KEY_ID=
AWS_REGION=us-east-1
# Legacy Supabase Storage (fallback if S3 not configured):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-anon-key
# SUPABASE_BUCKET=dd214-uploads
# Local-disk DD-214 encryption (fallback only) — Fernet key:
# DD214_ENCRYPTION_KEY=

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
# Extra CORS origins (comma-separated) — e.g. the CloudFront/app domain:
CORS_ORIGINS=https://silenthonorfoundation.org,https://www.silenthonorfoundation.org

# ── File Upload ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=/app/uploads
