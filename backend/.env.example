# Silent Honor Foundation — Backend Configuration
# Copy to `.env` and fill in real values. NEVER commit the filled-in .env (it is gitignored).
# In AWS, these are injected by App Runner: plain values as env vars, secrets from
# AWS Secrets Manager (silenthonor/jwt-secret, /admin-password, /mongodb-uri, /resend-api-key).

# ── Database ────────────────────────────────────────────────────────────────
# Either MONGO_URL/DB_NAME or MONGODB_URI/MONGODB_DB is accepted.
# Local MongoDB:
MONGO_URL=mongodb://localhost:27017
DB_NAME=silenthonor
# Amazon DocumentDB (set instead of the above in AWS). Note tls params + CA bundle:
# MONGODB_URI=mongodb://<user>:<pass>@<cluster-endpoint>:27017/?tls=true&tlsCAFile=/app/rds-global-bundle.pem&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
# MONGODB_DB=silenthonor

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# REQUIRED in production. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-generate-a-long-random-value
JWT_EXPIRY_HOURS=24

# Seed admin, created/reset on startup. CHANGE THESE — never ship defaults.
ADMIN_EMAIL=admin@silenthonorfoundation.org
ADMIN_PASSWORD=change-me-strong-password

# ── Application ─────────────────────────────────────────────────────────────
# ENVIRONMENT=production disables writing the dev test_credentials.md file.
ENVIRONMENT=development
# Used to build links in outbound email (password reset). Must be the PUBLIC site URL.
FRONTEND_URL=http://localhost:3000
# EXTRA allowed browser origins (comma-separated). The production domains and localhost
# are always allowed in code — this only ADDS (e.g. a CloudFront or preview domain).
CORS_ORIGINS=

# ── Email ───────────────────────────────────────────────────────────────────
# Provider: "resend" (default) or "ses"
EMAIL_PROVIDER=resend
FROM_EMAIL=Silent Honor <noreply@silenthonorfoundation.org>
# Resend (used when EMAIL_PROVIDER=resend):
RESEND_API_KEY=re_your_resend_api_key
# SES uses the instance role / AWS credential chain — no key needed.

# ── File storage (DD-214 + member documents) ────────────────────────────────
# Amazon S3 (preferred). When S3_BUCKET is set, DD-214 + documents go to S3.
S3_BUCKET=silenthonor-uploads-802104113048
S3_KMS_KEY_ID=
AWS_REGION=us-east-1
# Legacy Supabase Storage (fallback if S3 not configured):
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-supabase-anon-key
# SUPABASE_BUCKET=dd214-uploads
# Local-disk DD-214 encryption (fallback only, AES-256 Fernet key).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DD214_ENCRYPTION_KEY=

# ── File upload / paths ─────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
# Where uploads are written when using local disk (defaults to /app/uploads).
UPLOADS_DIR=/app/uploads
# Frontend dir is auto-detected; override only if index.html/css/js live elsewhere.
# APP_DIR=/app
# PORT=8000
